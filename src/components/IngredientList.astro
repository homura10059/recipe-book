---
import type { Ingredient } from '../lib/cooklang';
import { formatIngredientQuantity } from './formatIngredientQuantity';

interface Props {
  ingredients: Ingredient[];
}

const { ingredients } = Astro.props;
---
<ul class="space-y-1">
  {ingredients.map((ingredient) => {
    const qty = formatIngredientQuantity(ingredient.quantity, ingredient.units);
    return (
      <li class="flex gap-2 text-neutral-700">
        {qty ? <span class="text-neutral-400">{qty}</span> : null}
        <span>{ingredient.name}</span>
      </li>
    );
  })}
</ul>
