---
import { Image } from 'astro:assets';
import { formatDate } from '../lib/formatDate';
import { isOptimizableImage } from '../lib/image';
import type { Recipe } from '../lib/microcms';
import CategoryBadge from './CategoryBadge.astro';
import TagList from './TagList.astro';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---
<a href={`/recipes/${recipe.slug}`} class="group block rounded-lg overflow-hidden border border-stone-200 shadow-sm hover:shadow-md hover:border-mustard transition-all bg-white">
  {recipe.thumbnail?.url ? (
    isOptimizableImage(recipe.thumbnail.url) ? (
      <Image
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    ) : (
      <img
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    )
  ) : (
    <div class="w-full aspect-video bg-stone-100 flex items-center justify-center">
      <span class="text-stone-400 text-sm">No image</span>
    </div>
  )}
  <div class="p-5 space-y-3">
    <h2 class="text-lg text-stone-800 group-hover:text-mustard transition-colors leading-snug">{recipe.title}</h2>
    <div class="flex items-center gap-3">
      <CategoryBadge name={recipe.category.name} slug={recipe.category.slug} />
      <time datetime={recipe.publishedAt} class="text-xs text-stone-400 font-sans">
        {formatDate(recipe.publishedAt)}
      </time>
    </div>
    {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
  </div>
</a>
