---
import TagList from './TagList.astro';
import type { Recipe } from '../lib/microcms';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---
<a href={`/recipes/${recipe.slug}`} class="group block border border-stone-200 hover:border-mustard transition-colors">
  <img
    src={recipe.thumbnail?.url ?? 'https://i.imgur.com/AHdiQf2.webp'}
    alt={recipe.title}
    width={recipe.thumbnail?.width ?? 400}
    height={recipe.thumbnail?.height ?? 400}
    class="w-full aspect-video object-cover"
  />
  <div class="p-5 space-y-3">
    <h2 class="text-lg text-stone-800 group-hover:text-mustard transition-colors">{recipe.title}</h2>
    {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
  </div>
</a>
