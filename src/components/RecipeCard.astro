---
import { Image } from 'astro:assets';
import { isOptimizableImage } from '../lib/image';
import type { Recipe } from '../lib/microcms';
import TagList from './TagList.astro';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---
<div class="border border-neutral-200 hover:border-accent transition-colors rounded-lg overflow-hidden">
<a href={`/recipes/${recipe.slug}`} class="group block">
  {recipe.thumbnail?.url ? (
    isOptimizableImage(recipe.thumbnail.url) ? (
      <Image
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    ) : (
      <img
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    )
  ) : (
    <div class="w-full aspect-video bg-neutral-100 flex items-center justify-center">
      <span class="text-neutral-400 text-xs tracking-widest uppercase">No image</span>
    </div>
  )}
  <div class="p-5 space-y-3">
    <p class="text-xs tracking-widest uppercase text-neutral-400">{recipe.category.name}</p>
    <h2 class="text-base text-neutral-900 group-hover:text-accent transition-colors leading-snug">{recipe.title}</h2>
    {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
    <p class="text-xs text-neutral-400">更新: {new Date(recipe.updatedAt).toLocaleDateString('ja-JP')}</p>
  </div>
</a>
</div>
