---
import { Image } from 'astro:assets';
import { isOptimizableImage } from '../lib/image';
import type { Recipe } from '../lib/microcms';
import TagList from './TagList.astro';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---
<div class="border border-divider hover:border-accent transition-colors overflow-hidden">
<a href={`/recipes/${recipe.slug}`} class="group block">
  {recipe.thumbnail?.url ? (
    isOptimizableImage(recipe.thumbnail.url) ? (
      <Image
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    ) : (
      <img
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    )
  ) : (
    <div class="w-full aspect-video bg-surface-elevated flex items-center justify-center">
      <span class="text-ink-muted text-sm font-mono">No image</span>
    </div>
  )}
  <div class="p-5 space-y-3">
    <p class="text-xs font-mono uppercase text-ink-muted">{recipe.category.name}</p>
    <h2 class="text-lg text-ink-body group-hover:text-accent transition-colors">{recipe.title}</h2>
    {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
    <p class="text-xs font-mono text-ink-muted">更新: {new Date(recipe.updatedAt).toLocaleDateString('ja-JP')}</p>
  </div>
</a>
</div>
