---
import { Image } from 'astro:assets';
import { formatDate } from '../lib/formatDate';
import { isOptimizableImage } from '../lib/image';
import type { Recipe } from '../lib/microcms';
import CategoryBadge from './CategoryBadge.astro';
import TagList from './TagList.astro';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---
<a
  href={`/recipes/${recipe.slug}`}
  class="group relative block rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all aspect-[4/3]"
>
  {recipe.thumbnail?.url ? (
    isOptimizableImage(recipe.thumbnail.url) ? (
      <Image
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <img
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    )
  ) : (
    <div class="absolute inset-0 bg-stone-200 flex items-center justify-center">
      <span class="text-stone-400 text-sm">No image</span>
    </div>
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
  <div class="absolute bottom-0 left-0 right-0 p-4 space-y-2">
    <div class="flex items-center gap-2">
      <CategoryBadge name={recipe.category.name} slug={recipe.category.slug} />
      <time datetime={recipe.publishedAt} class="text-xs text-white/70 font-sans">
        {formatDate(recipe.publishedAt)}
      </time>
    </div>
    <h2 class="text-base font-semibold text-white leading-snug group-hover:text-mustard transition-colors">
      {recipe.title}
    </h2>
    {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
  </div>
</a>
