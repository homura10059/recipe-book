---
---
<header class="border-b border-stone-200 px-6 py-5">
  <div class="flex items-center justify-between">
    <a href="/" class="text-xl tracking-widest lowercase text-stone-800 hover:text-mustard transition-colors">
      recipe book
    </a>
    <div class="relative" id="menu-container">
      <button
        id="menu-button"
        aria-expanded="false"
        aria-label="メニューを開く"
        class="text-stone-800 hover:text-mustard transition-colors p-1"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
      <nav
        id="menu-nav"
        class="hidden absolute right-0 top-full mt-2 bg-background border border-stone-200 shadow-sm rounded py-2 min-w-40 z-10"
      >
        <a href="/about" class="block px-5 py-2 text-stone-700 hover:text-mustard hover:bg-stone-100 transition-colors">
          About
        </a>
        <a href="/privacy-policy" class="block px-5 py-2 text-stone-700 hover:text-mustard hover:bg-stone-100 transition-colors">
          プライバシーポリシー
        </a>
        <a href="/disclaimer" class="block px-5 py-2 text-stone-700 hover:text-mustard hover:bg-stone-100 transition-colors">
          免責事項
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById('menu-button');
  const nav = document.getElementById('menu-nav');
  const container = document.getElementById('menu-container');

  button?.addEventListener('click', () => {
    const isHidden = nav?.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(!isHidden));
  });

  document.addEventListener('click', (e) => {
    if (!container?.contains(e.target as Node)) {
      nav?.classList.add('hidden');
      button?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
