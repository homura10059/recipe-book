---
import { Image } from 'astro:assets';
import CategoryBadge from '../../components/CategoryBadge.astro';
import RecipeTabs from '../../components/RecipeTabs.astro';
import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { parseCooklang } from '../../lib/cooklang';
import { isOptimizableImage } from '../../lib/image';
import { getAllRecipes } from '../../lib/microcms';
import { getOgImageUrl } from '../../lib/ogp';

export async function getStaticPaths() {
  const recipes = await getAllRecipes();
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { ingredients, steps, metadata } = parseCooklang(recipe.body);
---
<BaseLayout title={`${recipe.title} | homura's recipe book`} ogImage={getOgImageUrl(recipe.thumbnail?.url)}>
  <article class="max-w-2xl mx-auto space-y-10">
    {recipe.thumbnail?.url ? (
      isOptimizableImage(recipe.thumbnail.url) ? (
        <Image
          src={recipe.thumbnail.url}
          alt={recipe.title}
          width={recipe.thumbnail.width}
          height={recipe.thumbnail.height}
          class="w-full aspect-video object-cover"
        />
      ) : (
        <img
          src={recipe.thumbnail.url}
          alt={recipe.title}
          width={recipe.thumbnail.width}
          height={recipe.thumbnail.height}
          class="w-full aspect-video object-cover"
        />
      )
    ) : (
      <div class="w-full aspect-video bg-neutral-100 flex items-center justify-center">
        <span class="text-neutral-400 text-xs tracking-widest uppercase">No image</span>
      </div>
    )}

    <header class="space-y-4">
      <h1 class="text-2xl text-neutral-900 tracking-tight">{recipe.title}</h1>
      <div class="flex flex-wrap items-center gap-3">
        {recipe.category && (
          <CategoryBadge name={recipe.category.name} slug={recipe.category.slug} />
        )}
        {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
      </div>
      {Object.keys(metadata).length > 0 && (
        <dl class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-neutral-400 tracking-wide">
          {Object.entries(metadata).map(([key, value]) => (
            <div class="flex gap-1">
              <dt class="uppercase">{key}:</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      )}
    </header>

    {(ingredients.length > 0 || steps.length > 0) && (
      <RecipeTabs body={recipe.body} ingredients={ingredients} steps={steps} />
    )}
  </article>
</BaseLayout>
