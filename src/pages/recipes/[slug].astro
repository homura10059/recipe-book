---
import { Image } from 'astro:assets';
import CategoryBadge from '../../components/CategoryBadge.astro';
import IngredientList from '../../components/IngredientList.astro';
import StepList from '../../components/StepList.astro';
import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { parseCooklang } from '../../lib/cooklang';
import { getAllRecipes } from '../../lib/microcms';

export async function getStaticPaths() {
  const recipes = await getAllRecipes();
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { ingredients, steps, metadata } = parseCooklang(recipe.body);
---
<BaseLayout title={`${recipe.title} | recipe book`}>
  <article class="max-w-2xl mx-auto space-y-10">
    {recipe.thumbnail?.url ? (
      <Image
        src={recipe.thumbnail.url}
        alt={recipe.title}
        width={recipe.thumbnail.width}
        height={recipe.thumbnail.height}
        class="w-full aspect-video object-cover"
      />
    ) : (
      <div class="w-full aspect-video bg-stone-100 flex items-center justify-center">
        <span class="text-stone-400 text-sm">No image</span>
      </div>
    )}

    <header class="space-y-4">
      <h1 class="text-3xl text-stone-800">{recipe.title}</h1>
      <div class="flex flex-wrap items-center gap-3">
        {recipe.category && (
          <CategoryBadge name={recipe.category.name} slug={recipe.category.slug} />
        )}
        {recipe.tags.length > 0 && <TagList tags={recipe.tags} />}
      </div>
      {Object.keys(metadata).length > 0 && (
        <dl class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-stone-500">
          {Object.entries(metadata).map(([key, value]) => (
            <div class="flex gap-1">
              <dt class="capitalize">{key}:</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      )}
    </header>

    {ingredients.length > 0 && (
      <section class="space-y-4">
        <h2 class="text-sm tracking-widest uppercase text-stone-400">Ingredients</h2>
        <IngredientList ingredients={ingredients} />
      </section>
    )}

    {steps.length > 0 && (
      <section class="space-y-4">
        <h2 class="text-sm tracking-widest uppercase text-stone-400">Steps</h2>
        <StepList steps={steps} />
      </section>
    )}
  </article>
</BaseLayout>
