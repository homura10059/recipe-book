{
  "name": "recipe-book",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks",
    "deploy": "wrangler pages deploy dist/"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.100",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.0",
    "astro-icon": "^1.1.5",
    "microcms-js-sdk": "^3.1.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@biomejs/biome": "^1.9.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.76.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx biome check --write --staged .",
    "pre-push": "npm run typecheck && npm run test"
  }
}
